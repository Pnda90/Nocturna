# Supabase Configuration
# Get these from your Supabase project dashboard
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Edge Functions Environment Variables
# Set these in your Supabase dashboard under Settings > Edge Functions
LOVABLE_API_KEY=your_api_key_here

# CORS Configuration (optional, for Supabase functions)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,https://nocturna.app
